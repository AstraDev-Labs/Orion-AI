# --- GROQ (Reasoning & Fast Whisper) ---
GROQ_API_KEY=
REASONING_PROVIDER=groq
LOGIC_MODEL=llama3.2:1b
REFINER_MODEL=llama3.2:1b


# --- DEEPGRAM (Ultra-Fast STT) ---
DEEPGRAM_API_KEY=
STT_MODEL_SIZE=deepgram # Set to 'deepgram' to use Nova-3

# --- ELEVENLABS (Premium TTS) ---
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=
TTS_PROVIDER=elevenlabs 
TTS_BATCH_WINDOW_MS=50

# --- LOCAL FALLBACKS & AUDIO ---
MIC_BACKEND=sounddevice
EDGE_TTS_VOICE=en-US-JennyNeural
VAD_THRESHOLD=0.015
VAD_SILENCE_CHUNKS=12
ENABLE_VISION_CONTEXT=1

# --- NEURAL MEMORY (RAG & Learning) ---
OBSIDIAN_VAULT_PATH=
MEMORY_MODEL=bert-base-nli-mean-tokens

# --- OLLAMA OVERRIDES ---
OLLAMA_HOST=127.0.0.1:11434